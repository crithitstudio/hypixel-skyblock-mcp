# Required for private/profile endpoints:
# https://developer.hypixel.net/
HYPIXEL_API_KEY=

# Optional tuning.
HYPIXEL_API_BASE=https://api.hypixel.net
MOJANG_API_BASE=https://api.mojang.com
HYPIXEL_CACHE_TTL_MS=60000
HYPIXEL_REQUEST_TIMEOUT_MS=15000

# Optional: external lowest-BIN price source for skyblock_networth auction-item
# pricing. Expects a JSON map of { "SKYBLOCK_ID": price }. Bazaar prices take
# precedence; this only fills in auction-only items.
# SKYBLOCK_LOWEST_BIN_URL=
# SKYBLOCK_LOWEST_BIN_TIMEOUT_MS=10000
