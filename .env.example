# Required for private/profile endpoints:
# https://developer.hypixel.net/
HYPIXEL_API_KEY=

# Optional tuning.
HYPIXEL_API_BASE=https://api.hypixel.net
MOJANG_API_BASE=https://api.mojang.com
HYPIXEL_CACHE_TTL_MS=60000
HYPIXEL_REQUEST_TIMEOUT_MS=15000
# Retries for rate-limited (429) and transient (502/503/504/network) responses.
# Honors Retry-After / RateLimit-Reset, otherwise capped exponential backoff.
HYPIXEL_MAX_RETRIES=2
# Upper bound on cached responses before the oldest entry is evicted.
HYPIXEL_CACHE_MAX_ENTRIES=500
# Official Hypixel SkyBlock Wiki integration used by skyblock_wiki_* tools and
# skyblock_item includeWiki enrichment.
SKYBLOCK_WIKI_BASE=https://wiki.hypixel.net
SKYBLOCK_WIKI_TIMEOUT_MS=10000
SKYBLOCK_WIKI_CACHE_TTL_MS=600000

# Optional: external lowest-BIN price source for skyblock_networth auction-item
# pricing. Expects a JSON map of { "SKYBLOCK_ID": price }. Bazaar prices take
# precedence; this only fills in auction-only items.
# SKYBLOCK_LOWEST_BIN_URL=
# SKYBLOCK_LOWEST_BIN_TIMEOUT_MS=10000
